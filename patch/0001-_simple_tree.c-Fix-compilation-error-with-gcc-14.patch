From a909234fc9e83443480618fb6cc1b155b7000e2c Mon Sep 17 00:00:00 2001
From: Ales Erjavec <ales.erjavec@fri.uni-lj.si>
Date: Thu, 9 May 2024 12:31:02 +0200
Subject: [PATCH] _simple_tree.c: Fix compilation error with gcc 14

Non standard `qsort_r` is not defined unless _GNU_SOURCE is defined or
`--std=gnu99` flag is used.
---
 Orange/classification/_simple_tree.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/Orange/classification/_simple_tree.c b/Orange/classification/_simple_tree.c
index 448c625dd..fe91cd2a2 100644
--- a/Orange/classification/_simple_tree.c
+++ b/Orange/classification/_simple_tree.c
@@ -1,3 +1,6 @@
+#if (defined __GLIBC__ || defined __GNU__ || defined __linux__)
+#define _GNU_SOURCE
+#endif
 #include <math.h>
 #include <float.h>
 #include <assert.h>
-- 
2.45.1

